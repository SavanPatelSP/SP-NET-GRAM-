<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.SPNetGram" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary_variant</item>
        <item name="colorOnSecondary">@color/text_on_primary</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorError">@color/error</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowTranslucentNavigation">false</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.SPNetGram.Dialog</item>
        <item name="bottomNavigationStyle">@style/Widget.SPNetGram.BottomNavigation</item>
    </style>

    <style name="Theme.SPNetGram.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/primary</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.SPNetGram</item>
    </style>

    <style name="Theme.SPNetGram.Dark" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/secondary</item>
        <item name="colorPrimaryVariant">@color/primary</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>
        <item name="colorSecondary">@color/diamond_blue</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/text_primary_dark</item>
        <item name="android:colorBackground">@color/background_dark</item>
        <item name="android:windowBackground">@color/background_dark</item>
        <item name="android:statusBarColor">@color/background_dark</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="ThemeOverlay.SPNetGram.Dialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnSurface">@color/text_primary</item>
    </style>

    <style name="Widget.SPNetGram.BottomNavigation" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="itemIconTint">@color/nav_item_selector</item>
        <item name="itemTextColor">@color/nav_item_selector</item>
        <item name="elevation">8dp</item>
    </style>

    <!-- Toolbar -->
    <style name="Theme.SPNetGram.Toolbar" parent="ThemeOverlay.MaterialComponents.Toolbar.Primary">
        <item name="colorControlNormal">@color/text_on_primary</item>
        <item name="colorPrimary">@color/primary</item>
    </style>

    <!-- Chat bubble styles -->
    <style name="ChatBubble.Outgoing" parent="">
        <item name="android:background">@drawable/bubble_outgoing</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">8dp</item>
    </style>

    <style name="ChatBubble.Incoming" parent="">
        <item name="android:background">@drawable/bubble_incoming</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">8dp</item>
    </style>

    <!-- SP Diamond premium card -->
    <style name="Card.Diamond" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/diamond_gold</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">8dp</item>
    </style>

    <!-- Glass effect overlay -->
    <style name="Glass.Overlay" parent="">
        <item name="android:alpha">0.85</item>
        <item name="android:background">@color/glass_tint_light</item>
    </style>

    <!-- Typography -->
    <style name="TextAppearance.SPNetGram.Title" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:fontFamily">@font/sp_font_bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.SPNetGram.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:fontFamily">@font/sp_font_regular</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.SPNetGram.Caption" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:fontFamily">@font/sp_font_regular</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>
</resources>
