<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Never back up sensitive data -->
        <exclude domain="sharedpref" path="spnetgram_secure_prefs.xml" />
        <exclude domain="sharedpref" path="spnetgram_secure_prefs_plain.xml" />
        <exclude domain="file" path="." />
        <exclude domain="database" path="." />
        <exclude domain="external" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="spnetgram_secure_prefs.xml" />
        <exclude domain="file" path="." />
        <exclude domain="database" path="." />
    </device-transfer>
</data-extraction-rules>
